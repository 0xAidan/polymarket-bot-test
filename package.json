{
  "name": "polymarket-copytrade-bot",
  "version": "1.0.0",
  "type": "module",
  "description": "Bot to copy trades from tracked wallets on Polymarket",
  "main": "dist/index.js",
  "scripts": {
    "setup": "node setup.cjs",
    "dev": "node start.cjs",
    "discovery:worker": "tsx src/discovery/discoveryWorker.ts",
    "dev:discovery": "tsx watch src/discovery/discoveryWorker.ts",
    "dev:app": "node start.cjs",
    "discovery:dev": "APP_RUNTIME=discovery-worker node start.cjs",
    "build": "tsc",
    "test": "node --test --import tsx tests/**/*.test.ts",
    "start": "node start.cjs",
    "start:app": "tsx src/index.ts",
    "start:discovery": "tsx src/discovery/discoveryWorker.ts",
    "start:prod:app": "node dist/index.js",
    "start:prod:discovery": "node dist/discovery/discoveryWorker.js",
    "lint": "eslint src --ext .ts",
    "validate:egress": "node scripts/validate-polymarket-egress.mjs"
  },
  "keywords": [
    "polymarket",
    "copytrading",
    "trading-bot",
    "crypto"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ethersproject/signing-key": "^5.8.0",
    "@polymarket/builder-relayer-client": "^0.0.8",
    "@polymarket/builder-signing-sdk": "^0.0.8",
    "@polymarket/clob-client": "^5.2.3",
    "@privy-io/server-auth": "^1.32.5",
    "axios": "^1.6.2",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "date-fns": "^3.0.6",
    "dotenv": "^16.3.1",
    "ethers": "^5.8.0",
    "express": "^4.18.2",
    "express-openid-connect": "^2.19.4",
    "express-rate-limit": "^8.3.1",
    "kalshi-typescript": "^3.6.0",
    "pino": "^10.3.1",
    "viem": "^2.46.3",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
