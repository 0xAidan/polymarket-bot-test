{
  "name": "polymarket-copytrade-bot",
  "version": "1.0.0",
  "type": "module",
  "description": "Bot to copy trades from tracked wallets on Polymarket",
  "main": "dist/index.js",
  "scripts": {
    "setup": "node setup.cjs",
    "dev": "node start.cjs",
    "discovery:worker": "tsx src/discovery/discoveryWorker.ts",
    "dev:discovery": "tsx watch src/discovery/discoveryWorker.ts",
    "dev:app": "node start.cjs",
    "discovery:dev": "tsx watch src/discovery/discoveryWorker.ts",
    "build": "tsc",
    "test": "node --test --import tsx tests/*.test.ts",
    "start": "node start.cjs",
    "start:app": "tsx src/index.ts",
    "start:discovery": "tsx src/discovery/discoveryWorker.ts",
    "start:prod:app": "node dist/index.js",
    "start:prod:discovery": "node dist/discovery/discoveryWorker.js",
    "lint": "eslint src --ext .ts",
    "validate:egress": "node scripts/validate-polymarket-egress.mjs",
    "verify:pnl": "DUCKDB_MEMORY_LIMIT_GB=${DUCKDB_MEMORY_LIMIT_GB:-5} DUCKDB_TEMP_DIR=${DUCKDB_TEMP_DIR:-/mnt/HC_Volume_105468668/duckdb_tmp} npx tsx scripts/verify-pnl-vs-polymarket-api.ts",
    "verify:pnl:smoke": "DUCKDB_MEMORY_LIMIT_GB=${DUCKDB_MEMORY_LIMIT_GB:-5} DUCKDB_TEMP_DIR=${DUCKDB_TEMP_DIR:-/mnt/HC_Volume_105468668/duckdb_tmp} npx tsx scripts/verify-pnl-vs-polymarket-api.ts --wallets 5",
    "verify:pnl:full": "DUCKDB_MEMORY_LIMIT_GB=${DUCKDB_MEMORY_LIMIT_GB:-5} DUCKDB_TEMP_DIR=${DUCKDB_TEMP_DIR:-/mnt/HC_Volume_105468668/duckdb_tmp} npx tsx scripts/verify-pnl-vs-polymarket-api.ts --wallets 20",
    "verify:pnl:dry-run": "DUCKDB_MEMORY_LIMIT_GB=${DUCKDB_MEMORY_LIMIT_GB:-5} DUCKDB_TEMP_DIR=${DUCKDB_TEMP_DIR:-/mnt/HC_Volume_105468668/duckdb_tmp} npx tsx scripts/verify-pnl-vs-polymarket-api.ts --dry-run",
    "verify:promotion-gate": "DUCKDB_MEMORY_LIMIT_GB=${DUCKDB_MEMORY_LIMIT_GB:-5} DUCKDB_TEMP_DIR=${DUCKDB_TEMP_DIR:-/mnt/HC_Volume_105468668/duckdb_tmp} npx tsx scripts/backfill/06_promotion_gate.ts",
    "verify:staging-display": "npx tsx scripts/verify-staging-discovery-display.ts",
    "verify:soak": "DUCKDB_MEMORY_LIMIT_GB=${DUCKDB_MEMORY_LIMIT_GB:-5} DUCKDB_TEMP_DIR=${DUCKDB_TEMP_DIR:-/mnt/HC_Volume_105468668/duckdb_tmp} npx tsx scripts/backfill/07_soak_report.ts",
    "purge:accounts": "tsx scripts/purge-hosted-accounts.ts",
    "discovery:preflight": "npx tsx scripts/backfill/00_preflight_capacity.ts --mode full-backfill",
    "discovery:preflight:forward": "npx tsx scripts/backfill/00_preflight_capacity.ts --mode forward-only",
    "discovery:run:full": "bash scripts/backfill/08_run_full_backfill_and_forward.sh"
  },
  "keywords": [
    "polymarket",
    "copytrading",
    "trading-bot",
    "crypto"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ethersproject/signing-key": "^5.8.0",
    "@polymarket/builder-relayer-client": "^0.0.8",
    "@polymarket/clob-client-v2": "^1.0.6",
    "@privy-io/server-auth": "^1.32.5",
    "@types/express-rate-limit": "^6.0.2",
    "axios": "^1.6.2",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "date-fns": "^3.0.6",
    "dotenv": "^16.3.1",
    "duckdb": "^1.4.4",
    "ethers": "^6.16.0",
    "express": "^4.18.2",
    "express-openid-connect": "^3.0.0",
    "express-rate-limit": "^8.5.2",
    "kalshi-typescript": "^3.6.0",
    "pino": "^10.3.1",
    "uplot": "^1.6.32",
    "viem": "^2.46.3",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^25.9.2",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3"
  }
}
